{% if settings.activate_custom_icons %}
  {% comment %} theme-check-disable RemoteAsset {% endcomment %}
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+{{ settings.icon_style | capitalize }}:opsz,wght,FILL,GRAD@20..48,{{ settings.icon_weight }},0..1,{{ settings.icon_grade }}&display=block"
    rel="stylesheet"
  >
  {% comment %} theme-check-enable RemoteAsset {% endcomment %}
{% endif %}
