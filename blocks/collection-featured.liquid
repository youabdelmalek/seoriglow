{% if block.settings.collection %}
  {% liquid
    assign collection = block.settings.collection | default: collections.all

    assign collection_products = collection.products

    if template.name == 'cart'
      for cart_item in cart.items
        assign collection_products = collection_products | reject: 'id', cart_item.product.id
      endfor
    endif
  %}

  <div
    class="
      block-collection-featured
      {%- if block.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
      {%- if block.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
      {%- if block.settings.additional_class != blank %} {{ block.settings.additional_class }}{% endif -%}
    "
    style="
      --margin-top: {{ block.settings.margin_top }}px;
      --margin-bottom: {{ block.settings.margin_bottom }}px
    "
    {{ block.shopify_attributes }}
  >
    <div
      class="block-collection-featured__inner"
      style="
        --padding-top: {{ block.settings.padding_top }}px;
        --padding-bottom: {{ block.settings.padding_bottom }}px
      "
    >
      {% if block.settings.layout_type == 'grid' %}
        <div
          class="block-collection-featured__grid"
          style="
            --grid-columns: {{ block.settings.grid_columns }};
            --grid-columns-mobile: {{ block.settings.grid_columns_mobile }};
          "
        >
          {% for product in collection_products limit: block.settings.max_products %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
          {% endfor %}
        </div>
      {% elsif block.settings.layout_type == 'slider' %}
        {% capture slides %}
        {% for product in collection_products limit: block.settings.max_products %}
          <li class="splide__slide">
            <div class="slide" style="--gap: 0px; --margin-top: 0px; --margin-bottom: 0px;">
              {% # theme-check-disable %}
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
              {% # theme-check-enable %}
            </div>
          </li>
        {% endfor %}
      {% endcapture %}

        {% render 'slider',
          block: section,
          slides: slides,
          gap: 16,
          per_page_desktop: block.settings.slider_items,
          per_page_mobile: block.settings.slider_items_mobile,
          show_arrows: block.settings.show_arrows,
          show_pagination: block.settings.show_pagination,
          rewind: block.settings.rewind
        %}
      {% endif %}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .block-collection-featured {
    width: 100%;
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
  }

  shopify-visual-preview-block-list .block-collection-featured .splide__arrow {
    display: none !important;
  }

  .block-collection-featured__inner {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .block-collection-featured__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    gap: var(--gap-md);
  }

  @media (width > 750px) {
    .block-collection-featured__grid {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:collection_featured",
  "tag": null,
  "blocks": [
    {
      "type": "_product-card"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "show_on_display",
      "label": "t:show_on_display",
      "default": "desktop_and_mobile",
      "options": [
        { "value": "desktop_and_mobile", "label": "t:desktop_and_mobile" },
        { "value": "desktop_only", "label": "t:desktop_only" },
        { "value": "mobile_only", "label": "t:mobile_only" }
      ]
    },
    {
      "type": "header",
      "content": "t:content"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:max_products",
      "min": 2,
      "max": 20,
      "default": 8,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:style"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:layout_type",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "t:grid" },
        { "value": "slider", "label": "t:slider" }
      ]
    },
    {
      "type": "header",
      "content": "t:grid",
      "visible_if": "{{ block.settings.layout_type == 'grid' }}"
    },
    {
      "type": "range",
      "id": "grid_columns",
