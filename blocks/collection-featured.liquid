    },
    {
      "type": "select",
      "id": "grid_columns_mobile",
      "label": "t:grid_columns_mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "visible_if": "{{ block.settings.layout_type == 'grid' }}"
    },
    {
      "type": "header",
      "content": "t:slider",
      "visible_if": "{{ block.settings.layout_type == 'slider' }}"
    },
    {
      "type": "range",
      "id": "slider_items",
      "label": "t:slider_items",
      "min": 2,
      "max": 5,
      "default": 4,
      "step": 1,
      "visible_if": "{{ block.settings.layout_type == 'slider' }}"
    },
    {
      "type": "select",
      "id": "slider_items_mobile",
      "label": "t:slider_items_mobile",
      "default": "1.8",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "1.8", "label": "1,8" },
        { "value": "2", "label": "2" }
      ],
      "visible_if": "{{ block.settings.layout_type == 'slider' }}"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:show_arrows",
      "default": true,
      "visible_if": "{{ block.settings.layout_type == 'slider' }}"
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "t:show_pagination",
      "default": false,
      "visible_if": "{{ block.settings.layout_type == 'slider' }}"
    },
    {
      "type": "checkbox",
      "id": "rewind",
      "label": "t:rewind",
      "default": false,
      "visible_if": "{{ block.settings.layout_type == 'slider' }}"
    },
    {
      "type": "header",
      "content": "t:paddings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:padding_top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:padding_bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "t:margin_top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:margin_bottom",
      "default": 0,
      "min": 0,
