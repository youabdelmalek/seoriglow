        "max_products": 8,
        "layout_type": "slider",
        "grid_columns": 4,
        "grid_columns_mobile": "2",
        "slider_items": 4,
        "slider_items_mobile": "2",
        "margin_top": 0,
        "margin_bottom": 0,
        "padding_top": 50,
        "padding_bottom": 50
      },
      "blocks": [
        {
          "type": "_product-card",
          "static": true,
          "id": "product-card",
          "settings": {
            "wrap_in_card": false,
            "color_scheme": "",
            "layout_gap": 10
          },
          "blocks": [
            {
              "type": "_product-card-media-gallery",
              "name": "t:product_card_gallery",
              "settings": {
                "show_slider": false,
                "media_rounded": true,
                "media_ratio": "1 / 1"
