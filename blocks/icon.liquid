{% doc %}
  Bloc icône.

  @example
  {% content_for 'block', type: 'icon', id: 'icon' %}
{% enddoc %}

<div
  class="
    icon-container
    {%- if block.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if block.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {%- if block.settings.additional_class != blank %} {{ block.settings.additional_class }}{% endif -%}
  "
>
  {% if block.settings.icon_type == 'icon' %}
    {% if settings.activate_custom_icons and block.settings.icon_custom != blank %}
      {% render 'icon', icon: block.settings.icon_custom %}
    {% else %}
      {% render 'icon', icon: block.settings.icon %}
    {% endif %}
  {% else %}
    {% assign image_width = block.settings.icon_size | times: 2 %}
    <img
      src="{{ block.settings.icon_image | image_url: width: image_width }}"
      alt="{{ block.settings.icon_image.alt }}"
      width="{{ block.settings.icon_size }}"
      height="{{ block.settings.icon_size | divided_by: block.settings.icon_image.aspect_ratio | ceil }}"
    >
  {% endif %}
</div>

{% style %}
  #shopify-block-{{ block.id }} {
    height: {{ block.settings.icon_size }}px;
  }

  #shopify-block-{{ block.id }} .icon {
    font-size: {{ block.settings.icon_size }}px !important;
    font-variation-settings:
      'FILL' var(--icon-fill),
      'wght' var(--icon-weight),
      'GRAD' var(--icon-grade),
      'opsz' {% if block.settings.icon_size <= 48 %}{{ block.settings.icon_size }}{% else %}48{% endif %};
  }
{% endstyle %}

