{% doc %}
  Affiche une icône avec un texte.

  @example
  {% content_for 'block', type: 'icon_with_text', id: 'icon_with_text' %}
{% enddoc %}

<div
  class="
    icon-with-text icon-with-text--{{ block.settings.layout_direction_desktop }}-desktop{% if block.settings.same_as_desktop == false %} icon-with-text--{{ block.settings.layout_direction_mobile }}-mobile{% else %} icon-with-text--{{ block.settings.layout_direction_desktop }}-mobile{% endif %} icon-with-text--{{ block.settings.text_style }}
    {%- if block.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if block.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {%- if block.settings.additional_class != blank %} {{ block.settings.additional_class }}{% endif -%}
  "
  style="
    --gap: {{ block.settings.layout_gap_desktop }}px;
    --margin-top: {{ block.settings.margin_top }}px;
    --margin-bottom: {{ block.settings.margin_bottom }}px;
    {% if block.settings.same_as_desktop == false -%}
    --gap-mobile: {{ block.settings.layout_gap_mobile }}px;
    {%- else -%}
    --gap-mobile: {{ block.settings.layout_gap_desktop }}px;
    {%- endif -%}
  "
  {{ block.shopify_attributes }}
  {% if request.visual_preview_mode %}
    data-visual-preview-mode
  {% endif %}
>
  {% if block.settings.icon_type == 'icon' %}
    {% if settings.activate_custom_icons and block.settings.icon_custom != blank %}
      {% assign icon = block.settings.icon_custom %}
    {% elsif block.settings.icon != 'none' %}
      {% assign icon = block.settings.icon %}
    {% endif %}
  {% else %}
    {% assign image_width = block.settings.icon_size | times: 2 %}
    {% capture icon_image %}
      <img
        src="{{ block.settings.icon_image | image_url: width: image_width }}"
        alt="{{ block.settings.icon_image.alt }}"
        width="{{ block.settings.icon_size }}"
        height="{{ block.settings.icon_size | divided_by: block.settings.icon_image.aspect_ratio | ceil }}"
      >
    {% endcapture %}
  {% endif %}

  {% if block.settings.icon_position == 'start' and icon != blank %}
    {% render 'icon', icon: icon %}
  {% elsif block.settings.icon_position == 'start' and icon_image != blank %}
    {{- icon_image -}}
  {% endif %}

  <div
    class="text-block {{ block.settings.text_style }}"
    style="--font-weight: {{ block.settings.font_weight }};"
  >
    {{ block.settings.text }}
  </div>

  {% if block.settings.icon_position == 'end' and icon != blank %}
    {% render 'icon', icon: icon %}
  {% elsif block.settings.icon_position == 'end' and icon_image != blank %}
    {{- icon_image -}}
  {% endif %}
</div>

{% style %}
  #shopify-block-{{ block.id }} .icon {
    font-size: {{ block.settings.icon_size }}px !important;
    height: {{ block.settings.icon_size }}px;
    font-variation-settings:
      'FILL' var(--icon-fill),
      'wght' var(--icon-weight),
      'GRAD' var(--icon-grade),
      'opsz' {% if block.settings.icon_size <= 48 %}{{ block.settings.icon_size }}{% else %}48{% endif %};
  }
{% endstyle %}

{% stylesheet %}
  .icon-with-text {
    display: flex;
    gap: var(--gap-mobile);
    overflow: hidden;
    width: 100%;
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
  }

  .icon-with-text .text-block {
    margin-top: 0;
    margin-bottom: 0;
  }

  .icon-with-text--row-mobile {
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
  }

  .icon-with-text--column-mobile {
    flex-direction: column;
    align-items: center;
    justify-content: center;

    .text-block.paragraph p {
      text-align: center;
    }
  }

  shopify-visual-preview-block-list .icon-with-text[data-visual-preview-mode] {
    width: 100%;
    max-width: 350px;
  }

  .text-block.paragraph p {
    font-weight: var(--font-weight);
  }

  .text-block.paragraph a {
    color: inherit;
  }

  @media (width > 750px) {
    .icon-with-text {
      gap: var(--gap);
    }

    .icon-with-text--row-desktop {
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;

      .text-block.paragraph p {
        text-align: left;
      }
    }

    .icon-with-text--column-desktop {
      flex-direction: column;
      align-items: center;
      justify-content: center;

      .text-block.paragraph p {
        text-align: center;
      }
    }
  }
{% endstylesheet %}

