{% liquid
  assign ratio = 1

  case block.settings.image_ratio
    when 'landscape'
      assign ratio = '4 / 3'
    when 'portrait'
      assign ratio = '4 / 5'
    when 'adapt'
      assign ratio = block.settings.image.aspect_ratio
  endcase

  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
%}

{% capture style %}
  --ratio: {{ ratio }};
{% endcapture %}

{% liquid
  assign media_width_desktop = '100vw'
  assign media_width_mobile = '100vw'
  assign sizes = 'auto, (min-width: 750px) ' | append: media_width_desktop | append: ', ' | append: media_width_mobile
  assign widths = '240, 352, 832, 1200, 1600, 1920, 2560, 3840'
%}

{% capture image %}
  {%- if block.settings.image -%}
    {% assign image_alt_default = 'placeholder.placeholder_image_alt' | t %}
    {% assign image_alt = block.settings.image.alt | append: ' ' | append: image_alt_default %}
    
    {{ block.settings.image
      | image_url: width: 3840
      | image_tag:
        width: block.settings.image.width,
        widths: widths,
        height: block.settings.image.height,
        class: 'image-block__image',
        sizes: sizes,
        alt: image_alt
    }} 
  {%- elsif block.settings.show_placeholder -%}
    {% if closest.article != blank %}
      <img src="{{ 'placeholder-article.jpg' | asset_img_url: 'x1000' }}" alt="placeholder article" width="750" height="750" class="image-block__image" loading="lazy">
    {% elsif closest.collection != blank %}
      <img src="{{ 'placeholder-collection.jpg' | asset_img_url: 'x1000' }}" alt="placeholder collection" width="750" height="750" class="image-block__image" loading="lazy">
    {% else %}
      <img src="{{ 'placeholder-image.jpg' | asset_img_url: 'x1000' }}" alt="placeholder image" width="750" height="750" class="image-block__image" loading="lazy">
    {% endif %}
  {%- endif -%} 
{% endcapture %}

{% if block.settings.link == blank %}
  <div
    class="
      image-block image-block--{{ block.id }}
      {%- if block.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
      {%- if block.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
      {%- if block.settings.additional_class != blank %} {{ block.settings.additional_class }}{% endif -%}
    "
    style="{{ style }} --width-desktop: {{ block.settings.image_width_desktop }}%; --width-mobile: {{ block.settings.image_width_mobile }}%;"
    {{ block.shopify_attributes }}
  >
    {{ image }}
  </div>
{% else %}
  <a
    href="{{ block.settings.link }}"
    class="
      image-block image-block--{{ block.id }}
      {%- if block.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
      {%- if block.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
      {%- if block.settings.additional_class != blank %} {{ block.settings.additional_class }}{% endif -%}
    "
    style="{{ style }} --width-desktop: {{ block.settings.image_width_desktop }}%; --width-mobile: {{ block.settings.image_width_mobile }}%;"
    {{ block.shopify_attributes }}
  >
    {{ image }}
  </a>
{% endif %}

{% stylesheet %}
  .image-block {
    width: var(--width-mobile);

    @media (width > 750px) {
      width: var(--width-desktop);
    }
  }

  .image-block__image,
  .placeholder-image {
    border-radius: var(--card-border-radius);
  }

  .image-block--height-fill .image-block__image {
    height: 100%;
  }

  .image-block__image {
    object-fit: cover;
    aspect-ratio: var(--ratio);
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:image",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "show_on_display",
      "label": "t:show_on_display",
      "default": "desktop_and_mobile",
      "options": [
        { "value": "desktop_and_mobile", "label": "t:desktop_and_mobile" },
        { "value": "desktop_only", "label": "t:desktop_only" },
        { "value": "mobile_only", "label": "t:mobile_only" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:image",
      "info": "t:image_info"
    },
    {
      "type": "checkbox",
      "id": "show_placeholder",
      "label": "t:show_placeholder_if_empty",
      "default": true,
      "info": "t:show_placeholder_if_empty_info",
      "visible_if": "{{ block.settings.image != blank }}"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:link"
    },
    {
      "type": "header",
      "content": "t:size"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:aspect_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:auto"
        },
        {
          "value": "portrait",
          "label": "t:portrait"
        },
        {
          "value": "square",
          "label": "t:square"
        },
        {
          "value": "landscape",
          "label": "t:landscape"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "t:image_width_desktop",
      "default": 100,
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "t:image_width_mobile",
      "default": 100,
      "min": 1,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "t:advanced_settings"
    },
    {
      "type": "text",
      "id": "additional_class",
      "label": "t:additional_class",
      "info": "t:additional_class_info"
    },
    {
      "type": "header",
      "content": "t:go_further"
    },
    {
      "type": "paragraph",
      "content": "t:go_further_description"
    }
  ],
  "presets": [
    {
      "name": "t:image",
      "category": "t:components",
      "settings": {
        "image_ratio": "adapt"
      }
    }
  ]
}
{% endschema %}
