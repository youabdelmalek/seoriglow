{% liquid
  assign ratio = 1

  case block.settings.image_ratio
    when 'landscape'
      assign ratio = '4 / 3'
    when 'portrait'
      assign ratio = '4 / 5'
    when 'adapt'
      assign ratio = block.settings.image.aspect_ratio
  endcase

  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
%}

<li class="splide__slide">
  <div
    class="
      review review--{{ block.settings.display_type }}
      {% if block.settings.wrap_in_card %} card color-{{ block.settings.color_scheme }}{% if block.settings.show_card_border %} card--with-border{% endif %}{% endif %}
    "
    style="--image-ratio: {{ ratio }};"
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-visual-preview-mode
    {% endif %}
  >
    {% render 'review', block: block %}
  </div>
</li>

