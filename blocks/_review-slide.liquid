          "value": "adapt",
          "label": "t:auto"
        },
        {
          "value": "portrait",
          "label": "t:portrait"
        },
        {
          "value": "square",
          "label": "t:square"
        },
        {
          "value": "landscape",
          "label": "t:landscape"
        }
      ],
      "default": "landscape",
      "visible_if": "{{ block.settings.display_type == '3' }}"
    },
    {
      "type": "select",
      "id": "source",
      "label": "t:video_source",
      "options": [
        {
          "value": "uploaded",
          "label": "t:video_uploaded"
        },
        {
          "value": "url",
          "label": "t:video_external_url"
        }
      ],
      "default": "uploaded",
      "visible_if": "{{ block.settings.display_type == '6' }}"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:video",
      "visible_if": "{{ block.settings.display_type == '6' and block.settings.source == 'uploaded' }}"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:video_external_url",
      "info": "t:video_external_info",
      "accept": ["youtube", "vimeo"],
      "visible_if": "{{ block.settings.display_type == '6' and block.settings.source == 'url' }}"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:title",
      "default": "Excellent produit !",
      "visible_if": "{{ block.settings.display_type == '2' or block.settings.display_type == '5' }}"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "t:content",
      "default": "<p>Écrivez un retour à propos de vos produits. Ajustez le nombre de colonnes en fonction de la taille moyenne des messages.</p>"
    },
    {
      "type": "image_picker",
      "id": "author_profile",
