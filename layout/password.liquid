<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Charger et précharger le CSS critique %}
    {{ 'reset.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag: preload: true }}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% render 'meta-tags' %}
    {% render 'fonts' %}
    {% render 'scripts' %}
    {% render 'css-variables' %}
    {% render 'color-schemes' %}

    {{ content_for_header }}
  </head>

  <body>
    {{ content_for_layout }}

    {% comment %} theme-check-disable RemoteAsset {% endcomment %}
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+{{ settings.icon_style | capitalize }}:opsz,wght,FILL,GRAD@20..48,{{ settings.icon_weight }},0..1,{{ settings.icon_grade }}"
      rel="stylesheet"
    >
    {% comment %} theme-check-enable RemoteAsset {% endcomment %}
  </body>
</html>
