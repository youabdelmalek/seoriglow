<script src="{{ 'product-card.js' | asset_url }}" type="module"></script>
<script src="{{ 'quick-add.js' | asset_url }}" type="module"></script>
<script src="{{ 'product-recommendations.js' | asset_url }}" type="module"></script>

<product-recommendations
  class="
    product-recommendations color-{{ section.settings.color_scheme }}
    {%- if section.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if section.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {{ section.settings.additional_class }}
  "
  style="
    --margin-top: {{ section.settings.margin_top }}px;
    --margin-bottom: {{ section.settings.margin_bottom }}px
  "
  data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.max_products }}"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div
    class="product-recommendations__inner page-width"
    style="
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    {% if recommendations.performed and recommendations.products_count > 0 %}
      {% content_for 'block', type: 'text', id: 'title' %}

      <div
        class="product-recommendations__grid"
        style="
          --grid-columns: {{ section.settings.grid_columns }};
          --grid-columns-mobile: {{ section.settings.grid_columns_mobile }};
        "
      >
        {% for product in recommendations.products limit: section.settings.max_products %}
          {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</product-recommendations>

{% stylesheet %}
  .product-recommendations {
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
    display: block;
  }

  .product-recommendations__inner {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    background-color: var(--color-background);
  }

  .product-recommendations__title {
    margin-bottom: var(--margin-lg);
  }

  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    gap: var(--gap-md);
  }

  @media (width > 750px) {
    .product-recommendations__grid {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:product_recommendations",
  "enabled_on": {
    "templates": ["product"]
  },
  "blocks": [
    {
      "type": "_product-card"
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "show_on_display",
      "label": "t:show_on_display",
      "default": "desktop_and_mobile",
      "options": [
        { "value": "desktop_and_mobile", "label": "t:desktop_and_mobile" },
        { "value": "desktop_only", "label": "t:desktop_only" },
        { "value": "mobile_only", "label": "t:mobile_only" }
      ]
    },
    {
      "type": "header",
      "content": "t:style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:max_products",
      "min": 2,
      "max": 4,
      "default": 4,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:grid"
    },
    {
      "type": "range",
      "id": "grid_columns",
      "label": "t:grid_columns_desktop",
      "min": 2,
      "max": 4,
      "default": 4,
      "step": 1
    },
    {
      "type": "select",
      "id": "grid_columns_mobile",
      "label": "t:grid_columns_mobile",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "header",
      "content": "t:paddings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:padding_top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:padding_bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "t:margin_top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:margin_bottom",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "t:advanced_settings"
    },
    {
      "type": "text",
      "id": "additional_class",
      "label": "t:additional_class",
      "info": "t:additional_class_info"
    },
    {
      "type": "header",
      "content": "t:go_further"
    },
    {
      "type": "paragraph",
      "content": "t:go_further_description"
    }
  ],
  "presets": [
    {
      "name": "t:product_recommendations",
      "category": "t:products",
      "settings": {
        "max_products": 4,
        "grid_columns": 4,
        "grid_columns_mobile": "2",
        "margin_top": 50,
        "margin_bottom": 50
      },
      "blocks": [
        {
          "type": "text",
          "id": "title",
          "static": true,
          "settings": {
            "show_on_display": "desktop_and_mobile",
            "text": "t:product_recommendations_title_default",
            "show_read_more": false,
            "read_more_length": 200,
            "text_style": "h3",
            "font_weight": 400,
            "alignment": "left",
            "margin_top": 0,
            "margin_bottom": 30,
            "additional_class": ""
          }
        },
        {
          "id": "product-card",
          "type": "_product-card",
          "static": true,
          "settings": {
            "wrap_in_card": false,
            "color_scheme": "",
            "layout_gap": 10
          },
          "blocks": [
            {
              "type": "_product-card-media-gallery",
              "name": "t:product_card_gallery",
              "settings": {
                "show_slider": false,
                "media_rounded": true,
                "media_ratio": "1 / 1"
              },
              "blocks": []
            },
            {
              "type": "_product-card-group",
              "name": "t:group",
              "settings": {
                "wrap_in_card": false,
                "color_scheme": "",
                "layout_direction_desktop": "column",
                "layout_gap_desktop": 5,
                "layout_wrap_desktop": "nowrap",
                "layout_justify_desktop": "flex-start",
                "layout_align_items_desktop": "flex-start",
                "same_as_desktop": true,
                "layout_direction_mobile": "column",
                "layout_gap_mobile": 10,
                "layout_wrap_mobile": "nowrap",
                "layout_justify_mobile": "flex-start",
                "layout_align_items_mobile": "flex-start",
                "margin_top": 10,
                "margin_bottom": 10
              },
              "blocks": [
                {
                  "type": "text",
                  "name": "t:text",
                  "settings": {
                    "text": "<h2>{{ closest.product.title }}</h2>",
                    "text_style": "paragraph",
                    "font_weight": 500,
                    "alignment": "left",
                    "margin_top": 0,
                    "margin_bottom": 0
                  }
                },
                {
                  "type": "product-price",
                  "name": "t:product_price",
                  "settings": {
                    "product": "{{ closest.product }}",
                    "sales_badge": "amount",
                    "show_sales_badge_text": false,
                    "text_style": "paragraph"
                  }
                },
                {
                  "type": "rating-stars",
                  "name": "t:rating_stars",
                  "settings": {
                    "product": "{{ closest.product }}",
                    "rating": 4.5,
                    "show_review_count": true,
                    "review_count": 123,
                    "link": "",
                    "margin_top": 0,
                    "margin_bottom": 0
                  }
                },
                {
                  "type": "_product-card-swatches",
                  "name": "t:swatches",
                  "settings": {
                    "swatches_size": "small",
                    "swatches_rounded": true
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
