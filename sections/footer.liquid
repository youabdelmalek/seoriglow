<footer
  class="footer footer--{{ section.settings.layout_type }} color-{{ section.settings.color_scheme }} {% if section.settings.show_top_border %}footer--top-border{% endif %}"
  style="
    --direction: {{ section.settings.layout_direction_desktop }};
    --wrap: {{ section.settings.layout_wrap_desktop }};
    --justify: {{ section.settings.layout_justify_desktop }};
    --align_items: {{ section.settings.layout_align_items_desktop }};
    --grid-columns: {{ section.settings.layout_grid_columns_desktop }};
    --gap: {{ section.settings.layout_gap_desktop }}px;
    --margin-top: {{ section.settings.margin_top }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;

    {% if section.settings.same_as_desktop == false -%}
    --direction-mobile: {{ section.settings.layout_direction_mobile }};
    --wrap-mobile: {{ section.settings.layout_wrap_mobile }};
    --justify-mobile: {{ section.settings.layout_justify_mobile }};
    --align_items-mobile: {{ section.settings.layout_align_items_mobile }};
    --grid-columns-mobile: {{ section.settings.layout_grid_columns_mobile }};
    --gap-mobile: {{ section.settings.layout_gap_mobile }}px;
    {%- else -%}
    --direction-mobile: {{ section.settings.layout_direction_desktop }};
    --wrap-mobile: {{ section.settings.layout_wrap_desktop }};
    --justify-mobile: {{ section.settings.layout_justify_desktop }};
    --align_items-mobile: {{ section.settings.layout_align_items_desktop }};
    --grid-columns-mobile: {{ section.settings.layout_grid_columns_desktop }};
    --gap-mobile: {{ section.settings.layout_gap_desktop }}px;
    {%- endif -%}
  "
  data-ref="footer"
>
  <div class="footer__content page-width">
    {% content_for 'blocks' %}
  </div>
  <div class="footer__bottom-bar">
    {% content_for 'block', type: '_footer-policy-list', id: 'footer-policy-list' %}
    {% content_for 'block', type: '_footer-bottom-bar', id: 'footer-bottom-bar' %}
  </div>
</footer>

{% stylesheet %}
  .footer-section {
    width: 100%;
    max-width: 100%;
    padding: 0;
  }

  .footer {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    margin-top: var(--margin-top);
  }

  .footer--top-border {
    border-top: var(--separator-border-thickness) solid var(--color-border);
  }

  .footer__content {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    grid-template-rows: auto;
    gap: var(--gap-mobile);
    width: 100%;
  }

  .footer--flex .footer__content {
    display: flex;
    flex-direction: var(--direction-mobile);
    flex-wrap: var(--wrap-mobile);
    justify-content: var(--justify-mobile);
    align-items: var(--align_items-mobile);
  }

  .footer--grid .footer__content {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    grid-template-rows: auto;
  }

  @media (width > 750px) {
    .footer__content {
      gap: var(--gap);
    }

    .footer--flex .footer__content {
      flex-direction: var(--direction);
      flex-wrap: var(--wrap);
      justify-content: var(--justify);
      align-items: var(--align_items);
    }

    .footer--grid .footer__content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }
  }
{% endstylesheet %}

