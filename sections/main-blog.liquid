<div
  class="main-blog color-{{ section.settings.color_scheme }}"
  style="--margin-top: {{ section.settings.margin_top }}px; --margin-bottom: {{ section.settings.margin_bottom }}px;"
>
  <div
    class="main-blog__articles page-width"
    style="
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    {% paginate blog.articles by 10 %}
      <div
        class="main-blog__articles-grid"
        style="
          --grid-columns: {{ section.settings.grid_columns }};
          --grid-columns-mobile: {{ section.settings.grid_columns_mobile }};
        "
      >
        {% if blog.articles.size > 0 %}
          {% for article in blog.articles %}
            {% content_for 'block', type: '_article-card', id: 'article-card', closest.article: article %}
          {% endfor %}
        {% else %}
          <p class="main-blog__empty">{{ 'blog.empty' | t }}</p>
        {% endif %}
      </div>

      {%- if paginate.pages > 1 -%}
        {% render 'pagination', paginate_object: paginate %}
      {%- endif -%}
    {% endpaginate %}
  </div>
</div>

{% stylesheet %}
  .main-blog {
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
  }

  .main-blog__articles {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .main-blog__articles-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    gap: var(--gap-lg);
  }

  @media (width > 750px) {
    .main-blog__articles-grid {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:blog",
  "enabled_on": {
    "templates": ["blog"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:style_desktop"
    },
    {
      "type": "range",
      "id": "grid_columns",
      "label": "t:layout_grid_columns",
      "default": 3,
      "min": 2,
      "max": 4,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:style_mobile"
    },
    {
      "type": "select",
      "id": "grid_columns_mobile",
      "label": "t:layout_grid_columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:paddings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:padding_top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:padding_bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "t:margin_top",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "t:margin_bottom",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:go_further"
    },
    {
      "type": "paragraph",
      "content": "t:go_further_description"
    }
  ]
}
{% endschema %}
