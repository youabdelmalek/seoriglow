<script src="{{ 'cart.js' | asset_url }}" type="module"></script>

<cart-component class="cart color-{{ section.settings.color_scheme }}">
  <div
    class="cart__inner page-width"
    style="
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    <div class="cart__header">
      <h1 class="h3">
        {{- 'cart.title' | t -}}
        {%- if section.settings.show_cart_count %} ({{ cart.item_count }}){%- endif -%}
      </h1>

      {% content_for 'block', type: '_cart-header-blocks', id: 'cart_header_blocks' %}
    </div>

    <div class="cart__content">
      <form class="cart__form" data-ref="cart-form" action="{{ routes.cart_url }}" method="post" id="cart_form">
        {% if cart.empty? %}
          <div class="cart__empty card">
            <p class="h6">{{ 'cart.empty_title' | t }}</p>

            <a href="{{ routes.root_url }}" class="button">
              {{ 'cart.continue_shopping' | t }}
            </a>
          </div>
        {% else %}
          <div class="cart__items">
            {%- assign previous_bundle_group = '' -%}
            {% for item in cart.items %}
              {%- assign bundle_name = '' -%}
              {%- assign current_bundle_group = '' -%}
              {%- assign has_visible_properties = false -%}
              {%- for property in item.properties -%}
                {%- assign property_first_char = property.first | slice: 0 -%}
                {%- if property.last != blank -%}
                  {%- if property.first == 'Bundle' and property_first_char != '_' -%}
                    {%- assign bundle_name = property.last -%}
                  {%- elsif property.first == '_bundle_group' -%}
                    {%- assign current_bundle_group = property.last -%}
                  {%- elsif property_first_char != '_' and property.first != 'Bundle item' -%}
                    {%- assign has_visible_properties = true -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              {%- assign selection_1_title = item.properties['_selection_1_title'] -%}
              {%- assign is_hidden_bundle = false -%}
              {%- if bundle_name != blank and current_bundle_group == blank and selection_1_title != blank -%}
                {%- assign is_hidden_bundle = true -%}
              {%- endif -%}
              {%- assign is_bundle_tail = false -%}
              {%- assign bundle_total_price = 0 -%}
              {%- assign bundle_compare_price = 0 -%}
              {%- assign next_bundle_group = '' -%}
              {%- unless forloop.last -%}
                {%- assign next_item = cart.items[forloop.index] -%}
                {%- assign next_bundle_group = next_item.properties._bundle_group -%}
              {%- endunless -%}
              {%- if current_bundle_group != blank -%}
                {%- if forloop.last -%}
                  {%- assign is_bundle_tail = true -%}
                {%- elsif next_bundle_group != current_bundle_group -%}
                  {%- assign is_bundle_tail = true -%}
                {%- endif -%}

                {%- if is_bundle_tail -%}
                  {%- for bundled_item in cart.items -%}
                    {%- assign bundled_group = bundled_item.properties._bundle_group -%}
                    {%- if bundled_group == current_bundle_group -%}
                      {%- assign bundle_total_price = bundle_total_price | plus: bundled_item.final_line_price -%}
                      {%- assign bundled_compare_price = bundled_item.original_price -%}
                      {%- if bundled_item.variant.compare_at_price > bundled_item.original_price -%}
                        {%- assign bundled_compare_price = bundled_item.variant.compare_at_price -%}
                      {%- endif -%}
                      {%- assign bundled_compare_price = bundled_compare_price | times: bundled_item.quantity -%}
                      {%- assign bundle_compare_price = bundle_compare_price | plus: bundled_compare_price -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endif -%}

              {%- if bundle_name != blank and current_bundle_group != previous_bundle_group -%}
                {%- assign cart_bundle_open = '<div class="cart__bundle-group"><div class="cart__bundle-group-header"><span class="cart__bundle-group-label">' | append: bundle_name | append: '</span></div>' -%}
                {{- cart_bundle_open -}}
              {%- endif -%}

              <cart-item
                data-index="{{ item.index | plus: 1 }}"
                class="cart__item card card--with-border{% if section.settings.show_remove_button == false %} cart__item--no-remove-button{% endif %}{% if current_bundle_group != blank %} cart__item--bundle{% endif %}{% if current_bundle_group != blank and is_bundle_tail == false %} cart__item--bundle-child{% endif %}{% if is_hidden_bundle %} cart__item--bundle-product{% endif %}"
                data-ref="cart-item"
                data-product-handle="{{ item.product.handle }}"
                data-current-quantity="{{ item.quantity }}"
                {% if current_bundle_group != blank %}
                  data-bundle-group="{{ current_bundle_group }}"
                {% endif %}
                {% if is_bundle_tail %}
                  data-bundle-tail="true"
                {% endif %}
              >
                {% if is_hidden_bundle %}
                {% elsif item.image %}
                  <a href="{{ item.url }}">
                    <img
                      src="{{ item.image | image_url: width: 150 }}"
                      alt="{{ item.product.title | default: item.product.title }}"
                      loading="lazy"
                      width="85"
                      height="{{ 85 | divided_by: item.image.aspect_ratio | ceil }}"
                    >
                  </a>
                {% else %}
                  <a href="{{ item.url }}">
                    <img
                      src="{{ 'placeholder-product.jpg' | asset_img_url: 'x150' }}"
                      alt="placeholder product"
                      width="85"
                      height="85"
                    >
                  </a>
                {% endif %}

                <div class="cart__item-wrapper">
                  <div class="cart__item-content">
                    {% if is_hidden_bundle %}
                      <div class="cart__bundle-product">
                        <div class="cart__bundle-product-header">
                          <span class="cart__bundle-product-label">{{ bundle_name }}</span>
                        </div>
                        <div class="cart__bundle-product-items">
                          {% for slot in (1..10) %}
                            {% assign selection_title_key = '_selection_' | append: slot | append: '_title' %}
                            {% assign selection_options_key = '_selection_' | append: slot | append: '_options' %}
                            {% assign selection_image_key = '_selection_' | append: slot | append: '_image' %}
                            {% assign selection_title = item.properties[selection_title_key] %}
                            {% assign selection_options = item.properties[selection_options_key] %}
                            {% assign selection_image = item.properties[selection_image_key] %}
                            {% if selection_title != blank %}
                              <div class="cart__bundle-product-item">
                                {% if selection_image != blank %}
                                  <img src="{{ selection_image }}" alt="{{ selection_title | escape }}" width="56" height="56">
                                {% endif %}
                                <div class="cart__bundle-product-item-details">
                                  <p class="cart__bundle-product-item-title">{{ selection_title }}</p>
                                  {% if selection_options != blank %}
                                    <p class="cart__bundle-product-item-options">{{ selection_options }}</p>
                                  {% endif %}
                                </div>
                              </div>
                            {% endif %}
                          {% endfor %}
                        </div>
                      </div>
                    {% else %}
                      <a href="{{ item.url }}" class="cart__item-name">
                        {{- item.product.title | escape -}}
                      </a>

                      {%- if item.product.has_only_default_variant == false -%}
                        <div class="cart__item-options">
                          {%- for option in item.options_with_values -%}
                            {%- if section.settings.show_variant_options_labels == false -%}
                              <span>
                                {{- option.value -}}
                                {%- unless forloop.last %}, {% endunless -%}
                              </span>
                            {%- else -%}
                              <div class="cart__item-option">
                                <span>{{ option.name }}:</span>
                                <span>{{ option.value -}}</span>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}

                      {%- if has_visible_properties -%}
                        <div class="cart__item-options">
                          {%- for property in item.properties -%}
                            {%- assign property_first_char = property.first | slice: 0 -%}
                            {%- if property.last != blank and property_first_char != '_' and property.first != 'Bundle' and property.first != 'Bundle item' -%}
                              <div class="cart__item-option">
                                <span>{{ property.first }}:</span>
                                <span>
                                  {%- if property.last contains '/uploads/' -%}
                                    <a href="{{ property.last }}" target="_blank">
                                      {{- property.last | split: '/' | last -}}
                                    </a>
                                  {%- else -%}
                                    {{ property.last }}
                                  {%- endif -%}
                                </span>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      {%- endif -%}

                      {%- if item.selling_plan_allocation.selling_plan != blank -%}
                        <div class="cart__item-options">
                          <p class="cart__item-option">
                            {{ item.selling_plan_allocation.selling_plan.name }}
                          </p>
                        </div>
                      {%- endif -%}
                    {% endif %}

                    {% if current_bundle_group == blank or is_bundle_tail %}
                      <div class="cart__item-prices{% if current_bundle_group != blank and is_bundle_tail %} cart__item-prices--bundle-tail{% endif %}">
                      <div class="cart__item-price">
                        {% assign compare_price = item.original_price %}
                        {% assign displayed_price = item.final_price %}
                        {% if item.variant.compare_at_price > item.original_price %}
                          {% assign compare_price = item.variant.compare_at_price %}
                        {% endif %}

                        {% if current_bundle_group != blank and is_bundle_tail %}
                          {% assign compare_price = bundle_compare_price %}
                          {% assign displayed_price = bundle_total_price %}
                        {% endif %}

                        {%- if compare_price > displayed_price -%}
                          {% render 'price', price: displayed_price, compare_price: compare_price, sales_badge: 'none' %}
                        {%- else -%}
                          {% render 'price', price: displayed_price, sales_badge: 'none' %}
                        {%- endif -%}

                        {% comment %}
                          Ancienne version qui fait le total de la ligne au lieu du prix unitaire :

                          {% assign compare_price = item.original_price %}
                          {% if item.variant.compare_at_price > item.original_price %}
                            {% assign compare_price = item.variant.compare_at_price | times: item.quantity %}
                          {% endif %}

                          {%- if compare_price > item.final_line_price -%}
                            {% render 'price', price: item.final_line_price, compare_price: compare_price, sales_badge: 'none' %}
                          {%- else -%}
                            {% render 'price', price: item.final_line_price, sales_badge: 'none' %}
                          {%- endif -%}
                        {% endcomment %}

                        <div class="cart__item-discounts">
                          {%- for discount in item.line_level_discount_allocations -%}
                            <span class="cart__item-discount badge badge--secondary badge--small">
                              {% render 'icon', icon: 'shoppingmode' %}
                              <span>{{ discount.discount_application.title }}</span>
                            </span>
                          {%- endfor -%}
                        </div>
                      </div>
                      </div>
                    {% endif %}
                  </div>

                  {% if current_bundle_group == blank or is_bundle_tail %}
                    <div class="cart__item-actions{% if current_bundle_group != blank and is_bundle_tail %} cart__item-actions--bundle-tail{% endif %}">
                      <div class="cart__item-actions-wrapper{% if current_bundle_group != blank and is_bundle_tail %} cart__item-actions-wrapper--bundle-tail{% endif %}">
                        {%- if section.settings.show_remove_button -%}
                          <div class="{% if current_bundle_group != blank and is_bundle_tail %}cart__bundle-remove{% endif %}">
                          {% assign data_ref = 'data-ref="remove-item"' %}
                          {% assign data = data_ref %}

                          {% render 'button', button_shape: 'small', button_style: 'secondary', icon: 'delete', data: data %}
                          </div>
                        {%- endif -%}

                        {% assign data_ref = 'data-ref="quantity-selector-input"' %}
                        {% assign data_buttons = 'data-ref="quantity-selector-button"' %}

                        {% assign max_quantity = item.variant.inventory_quantity %}
                        {% if item.variant.inventory_policy == 'continue' %}
                          {% assign max_quantity = 0 %}
                        {% endif %}

                        {% render 'quantity-selector',
                          small: true,
                          name: 'updates[]',
                          value: item.quantity,
                          min: -1,
                          max: max_quantity,
                          data_input: data_ref,
                          data_buttons: data_buttons
                        %}
                      </div>
                    </div>
                  {% endif %}
                </div>
              </cart-item>
              {%- if current_bundle_group != blank and is_bundle_tail -%}
                {{- '</div>' -}}
              {%- endif -%}
              {%- assign previous_bundle_group = current_bundle_group -%}
            {% endfor %}
          </div>
        {% endif %}

        <div class="cart__footer card card--with-border">
          {% content_for 'block', type: '_cart-footer-resume-blocks', id: 'cart_footer_resume_blocks' %}

          <div class="cart__ctas">
            <button
              type="submit"
              data-ref="checkout-button"
              class="button button--full-width"
              name="checkout"
              form="cart_form"
              {% if cart == empty %}
                disabled
              {% endif %}
            >
              <span>{{ 'cart.checkout' | t }}</span>
              {% render 'loading-spinner' %}
            </button>
          </div>

          {% content_for 'block', type: '_cart-footer-blocks', id: 'cart_footer_blocks' %}
        </div>
      </form>
    </div>
  </div>
</cart-component>

{% stylesheet %}
  .cart {
    display: block;
  }

  .cart__inner {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  :root {
    --cart-item-image-width: 85px;
  }

  .cart__empty {
    border: var(--container-border-thickness) solid var(--color-border);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--gap-sm);
  }

  .cart {
    padding-bottom: 3rem;
  }

  .cart__header {
    padding: var(--gap-md) 0;
  }

  .cart__form {
    display: grid;
    grid-template-columns: 100%;
    gap: var(--gap-md);
  }

  .cart__form--loading {
    opacity: 0.5;
    pointer-events: none;
  }

  @media (width > 750px) {
    .cart__header {
      padding: var(--gap-lg) 0;
    }

    .cart__form {
      grid-template-columns: 60% calc(40% - var(--gap-lg));
      gap: var(--gap-lg);
    }
  }

  .cart__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cart__bundle-group-header {
    margin: 0 0 0.15rem;
  }

  .cart__bundle-group-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .cart__bundle-remove {
    position: absolute;
    top: 0.45rem;
    right: 0.45rem;
    z-index: 2;
  }

  .cart__bundle-remove .button {
    min-width: 30px;
    min-height: 30px;
    padding: 0;
  }

  .cart__bundle-group {
    position: relative;
    padding: 0.55rem 0.65rem 0.45rem 1rem;
    border-radius: 12px;
    background: rgba(var(--color-foreground), 0.03);
  }

  .cart__bundle-group + .cart__bundle-group {
    margin-top: 0.4rem;
  }

  .cart__bundle-group::before {
    content: '';
    position: absolute;
    left: 0.45rem;
    top: 0.8rem;
    bottom: 0.7rem;
    width: 3px;
    border-radius: 999px;
    background: rgba(var(--color-foreground), 0.3);
  }

  .cart__bundle-group .cart__item {
    margin: 0;
  }

  .cart__bundle-group .cart__item + .cart__item {
    margin-top: 0.2rem;
  }

  .cart__bundle-group .cart__item.card {
    padding: 0.35rem 0;
    border: 0;
    box-shadow: none;
    background: transparent;
  }

  .cart__bundle-product {
    display: grid;
    gap: 0.8rem;
  }

  .cart__bundle-product-header {
    margin: 0;
  }

  .cart__bundle-product-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .cart__bundle-product-items {
    display: grid;
    gap: 0.7rem;
  }

  .cart__bundle-product-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .cart__bundle-product-item img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 10px;
    background: #fff;
    flex-shrink: 0;
  }

  .cart__bundle-product-item-details {
    min-width: 0;
  }

  .cart__bundle-product-item-title,
  .cart__bundle-product-item-options {
    margin: 0;
    line-height: 1.35;
  }

  .cart__bundle-product-item-title {
    font-size: var(--font-body--size);
    color: rgb(var(--color-foreground));
    font-weight: 500;
  }

  .cart__bundle-product-item-options {
    font-size: var(--font-body--size-small);
    color: rgba(var(--color-foreground), 0.8);
    margin-top: 0.2rem;
  }

  .cart__item--bundle-product .cart__item-prices {
    padding-left: calc(56px + 0.8rem);
  }

  .cart__bundle-group .cart__item-name {
    width: 100%;
  }

  .cart__item--bundle[data-bundle-tail='true'] .cart__item-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    min-height: auto;
  }

  .cart__item--bundle[data-bundle-tail='true'] .cart__item-actions {
    margin-left: auto;
  }

  .cart__footer {
    height: fit-content;
  }

  .cart__footer > *:not(:last-child) {
    margin-bottom: var(--padding-sm);
  }

  .cart__footer .accordion__content,
  .cart__footer .accordion__header {
    padding: var(--padding-xxs) 0;
  }

  /* Totals */

  .cart__totals,
  .cart__reductions {
    display: flex;
    justify-content: center;
    align-items: center;
    justify-content: space-between;
  }

  .cart__totals > * {
    color: rgb(var(--color-foreground));
    margin: 0;
    line-height: 1;
  }

  .cart__reductions p,
  .cart__totals p {
    font-weight: 500;
    margin: 0;
    line-height: normal;
  }

  .cart__reductions p,
  .cart__totals p,
  .cart__reductions-value,
  .cart__totals-value {
    font-size: var(--font-body--size-emphasized);
  }

  /* CTAs */

  .cart__ctas {
    text-align: center;
    display: flex;
    gap: 10px;
    margin-bottom: 0;
  }

  .cart__ctas button {
    width: 100%;
  }

  /* Item */

  .cart__item {
    background-color: var(--color-background);
    color: var(--color-foreground);
    display: flex;
    gap: var(--gap-sm);
    align-items: flex-start;
    max-width: 100%;
  }

  .cart__item > a {
    display: flex;
    align-items: center;
  }

  .cart__item img {
    width: var(--cart-item-image-width);
    object-fit: cover;
    background-color: white;
    max-width: fit-content;
    border-radius: calc(var(--card-border-radius) - var(--padding-sm));
  }

  .cart__item.card {
    padding: var(--padding-sm);

    img {
      border-radius: calc(var(--card-border-radius) - var(--padding-sm));
    }
  }

  .cart__item-options {
    line-height: normal;
    font-size: var(--font-body--size-small);
    word-break: break-word;
    color: rgba(var(--color-foreground), 0.8);
  }

  .cart__item-options .cart__item-option:not(:last-child) {
    margin-bottom: var(--padding-xs);
  }

  .cart__item-option {
    margin: 0;
  }

  .cart__item-content {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-top: 5px;
    min-width: 0;
    flex: 1;
  }

  .cart__item-wrapper {
    display: flex;
    justify-content: space-between;
    width: 100%;
    min-height: var(--cart-item-image-width);
    gap: var(--gap-sm);
  }

  .cart__item-name {
    text-decoration: none;
    display: block;
    width: calc(100% + 60px);
    font-size: var(--font-body--size);
    color: rgb(var(--color-foreground));
    font-weight: 500;
    line-height: normal;
    margin-bottom: 0;
    transition: var(--animation-link-hover);

    &:hover {
      opacity: var(--opacity-link-hover);
    }
  }

  .cart__item-prices {
    position: relative;
    width: 100%;
  }

  .cart__item-prices.loading {
    width: max-content;
  }

  .cart__item-prices--bundle-tail {
    margin-top: 0.35rem;
  }

  .cart__item-price {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    flex-wrap: wrap;
    font-size: var(--font-body--size-small);
    color: rgb(var(--color-foreground));
  }

  .cart__item-price > * {
    display: block;
    margin: 0;
    padding: 0;
    line-height: normal;
  }

  .cart__item-discounted-prices {
    display: flex;
    align-self: center;
    gap: 6px;
    line-height: normal;
  }

  .cart__item-compare-price {
    opacity: 0.7;
  }

  .cart__item--no-remove-button .cart__item-actions-wrapper {
    justify-content: flex-end;
  }

  .cart__item--no-remove-button .cart__item-name {
    width: calc(100% + var(--cart-item-image-width));
  }

  @media screen and (max-width: 350px) {
    .cart__item--no-remove-button .cart__item-name {
      width: calc(100% + 75px);
    }
  }

  @media screen and (max-width: 350px) {
    .cart__item img {
      width: var(--cart-item-image-width);
      max-height: calc(var(--cart-item-image-width) * 1.2);
    }

    .cart__item-content {
      gap: 5px;
    }

    .cart__item-wrapper {
      min-height: calc(var(--cart-item-image-width) * 1.2);
    }
    .cart__item-name {
      width: calc(100% + 50px);
    }

    .cart__item-prices {
      width: 100%;
    }
  }

  /* Quantity & Remove Button */

  .cart__item-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart__item-actions--bundle-tail {
    margin-top: 0;
  }

  .cart__item-actions-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-direction: column;
    height: 100%;
    gap: 5px;
  }

  .cart__item-actions-wrapper--bundle-tail {
    margin-top: 0;
    height: auto;
    align-items: flex-end;
    justify-content: flex-end;
    flex-direction: column;
  }

  .cart__item-actions-wrapper .button,
  .cart__item-actions-wrapper .quantity-selector {
    border: var(--inputs-border-width) solid var(--color-border);
  }

  @media screen and (max-width: 749px) {
    .cart__item-actions-wrapper {
      flex-wrap: wrap;
    }
  }

  /* Discounts */

  .cart__discounts {
    margin-bottom: 0;
  }

  .cart__discount {
    margin-bottom: var(--padding-sm);
  }

  .cart__item-discounts,
  .cart__discounts {
    font-size: 12px;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .cart__item-discount,
  .cart__discount {
    min-width: max-content;
    gap: var(--gap-xs);
  }

  .icon-discount {
    color: rgb(var(--color-foreground));
    width: 12px;
    height: 12px;
    margin-right: 7px;
  }

