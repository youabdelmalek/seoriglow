<div
  class="
    navigation navigation--{{ section.settings.display_mode }} color-{{ section.settings.color_scheme }}
    {%- if section.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if section.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {{- section.settings.additional_class -}}
  "
  style="
    --margin-bottom: {{ section.settings.margin_bottom }}px;
    --margin-top: {{ section.settings.margin_top }}px;
    --alignment-desktop: {{ section.settings.alignment_desktop }};
    --wrap: {{ section.settings.wrap }};
    --image-width-mobile: {{ section.settings.image_width_mobile }}px;
    --image-width-desktop: {{ section.settings.image_width_desktop }}px;
  "
>
  <div
    class="navigation__inner page-width"
    style="
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    <div class="navigation__track">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .navigation {
    width: 100%;
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
  }

  .navigation__inner {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .navigation__track {
    display: flex;
    gap: var(--gap-md);
    scrollbar-width: none;
    overflow-x: auto;
    padding-top: 5px;
    align-items: flex-start;
    justify-content: flex-start;
    flex-wrap: var(--wrap);
  }

  @media (width > 750px) {
    .navigation__track {
      justify-content: var(--alignment-desktop);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:navigation",
  "disabled_on": {
    "groups": ["footer", "custom.cart_drawer", "custom.breadcrumbs"]
  },
  "settings": [
    {
      "type": "select",
      "id": "show_on_display",
      "label": "t:show_on_display",
      "default": "desktop_and_mobile",
      "options": [
        { "value": "desktop_and_mobile", "label": "t:desktop_and_mobile" },
        { "value": "desktop_only", "label": "t:desktop_only" },
        { "value": "mobile_only", "label": "t:mobile_only" }
