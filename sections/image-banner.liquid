<div
  class="
    image-banner-wrapper color-{{ section.settings.color_scheme }}
    {%- if section.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if section.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {{ section.settings.additional_class }}
  "
  style="--margin-top: {{ section.settings.margin_top }}px; --margin-bottom: {{ section.settings.margin_bottom }}px;"
>
  <div
    class="image-banner-wrapper__inner {% if section.settings.full_width == false %} page-width image-banner-wrapper--children-cards{% endif %}"
    style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;"
  >
    {% capture banner_blocks %}
    {% content_for 'blocks' %}
  {% endcapture %}

    {% assign gap = 20 %}
    {% if section.settings.full_width %}
      {% assign gap = 0 %}
    {% endif %}

    {% if section.blocks.size > 1 %}
      {% render 'slider',
        slides: banner_blocks,
        gap: gap,
        per_page_mobile: 1,
        per_page_desktop: 1,
        show_arrows: section.settings.show_arrows,
        show_pagination: section.settings.show_pagination,
        rewind: section.settings.rewind,
        autoplay: section.settings.autoplay,
        autoplay_speed: section.settings.autoplay_speed
      %}
    {% else %}
      {{ banner_blocks }}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .image-banner-wrapper {
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
  }

  .image-banner-wrapper__inner {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .image-banner-wrapper--children-cards .image-banner {
    border-radius: var(--card-border-radius);
  }

  .image-banner-wrapper .splide__arrow {
    background-color: transparent;
    border: none;

    .icon {
      color: white;
    }
  }

  .image-banner-wrapper .splide__pagination {
    bottom: 5px;

    .splide__pagination__page,
    .splide__pagination__page.is-active {
      background: white;
    }
  }
{% endstylesheet %}

