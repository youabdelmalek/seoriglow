                "button_shape": "small",
                "icon": "arrow_forward",
                "icon_custom": "arrow_forward",
                "icon_position": "end",
                "margin_top": 0,
                "margin_bottom": 0
              }
            }
          ]
        },
        {
          "type": "_article-card",
          "static": true,
          "id": "article-card",
          "settings": {
            "wrap_in_card": false,
            "color_scheme": "scheme-2",
            "layout_gap": 15
          },
          "blocks": [
            {
              "type": "image",
              "name": "t:image",
              "settings": {
                "image": "{{ closest.article.image }}",
                "link": "",
                "image_ratio": "landscape"
              }
            },
            {
              "type": "_article-group",
              "name": "t:blog_featured_article_info_default",
              "settings": {
                "wrap_in_card": false,
                "color_scheme": "scheme-3",
                "layout_direction_desktop": "column",
                "layout_gap_desktop": 5,
                "layout_wrap_desktop": "nowrap",
                "layout_justify_desktop": "flex-start",
                "layout_align_items_desktop": "flex-start",
                "same_as_desktop": true,
                "layout_direction_mobile": "column",
                "layout_gap_mobile": 10,
                "layout_wrap_mobile": "nowrap",
                "layout_justify_mobile": "flex-start",
                "layout_align_items_mobile": "flex-start",
                "margin_top": 0,
                "margin_bottom": 0
              },
              "blocks": [
                {
                  "type": "text",
                  "name": "t:text",
                  "settings": {
                    "text": "<p>{{ closest.article.title }}</p>",
                    "text_style": "paragraph",
                    "font_weight": 500,
                    "alignment": "left",
                    "margin_top": 0,
                    "margin_bottom": 0
                  }
                },
                {
                  "type": "text",
                  "name": "t:text",
                  "settings": {
                    "text": "<p>{{ closest.article.excerpt }}</p>",
                    "text_style": "paragraph",
                    "font_weight": 400,
                    "alignment": "left",
                    "margin_top": 0,
                    "margin_bottom": 0
                  }
                },
                {
                  "type": "_article-group",
                  "name": "t:blog_featured_author_and_date_default",
                  "settings": {
                    "wrap_in_card": false,
                    "color_scheme": "scheme-2",
                    "layout_direction_desktop": "row",
                    "layout_gap_desktop": 10,
                    "layout_wrap_desktop": "nowrap",
                    "layout_justify_desktop": "space-between",
                    "layout_align_items_desktop": "center",
