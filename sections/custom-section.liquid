<div
  class="
    custom-section
    custom-section--{{ section.settings.layout_type }}
    custom-section--{{ section.settings.layout_flex_direction_desktop }}-desktop
    {% if section.settings.same_as_desktop == false %}
      custom-section--{{ section.settings.layout_flex_direction_mobile }}-mobile
    {% else %}
      custom-section--{{ section.settings.layout_flex_direction_desktop }}-mobile
    {% endif %}
    color-{{ section.settings.color_scheme }}
    {%- if section.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if section.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {{ section.settings.additional_class }}
  "
  style="
    --direction: {{ section.settings.layout_flex_direction_desktop }};
    --wrap: {{ section.settings.layout_flex_wrap_desktop }};
    --justify: {{ section.settings.layout_flex_justify_desktop }};
    --align_items: {{ section.settings.layout_flex_align_items_desktop }};
    --grid-columns: {{ section.settings.layout_grid_columns_desktop }};
    --gap: {{ section.settings.layout_gap_desktop }}px;
    --margin-top: {{ section.settings.margin_top }}px;
    --margin-bottom: {{ section.settings.margin_bottom }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    {% if section.settings.same_as_desktop == false -%}
    --direction-mobile: {{ section.settings.layout_flex_direction_mobile }};
    --wrap-mobile: {{ section.settings.layout_flex_wrap_mobile }};
    --justify-mobile: {{ section.settings.layout_flex_justify_mobile }};
    --align_items-mobile: {{ section.settings.layout_flex_align_items_mobile }};
    --grid-columns-mobile: {{ section.settings.layout_grid_columns_mobile }};
    --gap-mobile: {{ section.settings.layout_gap_mobile }}px;
    {%- else -%}
    --direction-mobile: {{ section.settings.layout_flex_direction_desktop }};
    --wrap-mobile: {{ section.settings.layout_flex_wrap_desktop }};
    --justify-mobile: {{ section.settings.layout_flex_justify_desktop }};
    --align_items-mobile: {{ section.settings.layout_flex_align_items_desktop }};
    --grid-columns-mobile: {{ section.settings.layout_grid_columns_desktop }};
    --gap-mobile: {{ section.settings.layout_gap_desktop }}px;
    {%- endif -%}
  "
>
  <div
    class="
      page-width
      {% if section.settings.wrap_in_card == false %}custom-section__inner{% endif %}
      {% if section.settings.section_width == 'narrow' %} page-width--narrow{% endif %}
    "
    style="
      --padding-top: {{ section.settings.padding_top }}px;
      --padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    {% capture blocks_content %}
      {% content_for 'blocks' %}
    {% endcapture %}

    {% if section.settings.wrap_in_card %}
      <div class="custom-section__inner card color-{{ section.settings.color_scheme_card }}">
        {{ blocks_content }}
      </div>
    {% else %}
      {{ blocks_content }}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .section-custom-section {
    width: 100%;
    max-width: 100%;
    padding: 0;
  }

  .section-custom-section .text-block[data-visual-preview-mode] {
    max-width: 100%;
  }

  .section-custom-section .image-card[data-visual-preview-mode] {
    width: 100%;
  }

  .custom-section {
    width: 100%;
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
    display: flex;
    justify-content: center;
  }

  .custom-section .custom-section__inner {
    gap: var(--gap-mobile);
    width: 100%;
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .custom-section--flex .custom-section__inner {
    display: flex;
    flex-direction: var(--direction-mobile);
    flex-wrap: var(--wrap-mobile);
    justify-content: var(--justify-mobile);
    align-items: var(--align_items-mobile);
    height: 100%;
  }

  .custom-section:not(.custom-section--row-mobile) > div > .custom-section__inner > .text-block-center-mobile,
  .custom-section:not(.custom-section--row-mobile) > .custom-section__inner > .text-block-center-mobile {
    width: 100%;
  }

  .custom-section--grid .custom-section__inner {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    grid-template-rows: auto;
  }

  @media (width > 750px) {
    .custom-section .custom-section__inner {
      gap: var(--gap);
    }

    .custom-section--flex .custom-section__inner {
      flex-direction: var(--direction);
      flex-wrap: var(--wrap);
      justify-content: var(--justify);
      align-items: var(--align_items);
      height: auto;
    }

    .custom-section:not(.custom-section--row-desktop) > div > .custom-section__inner > .text-block-center-desktop,
    .custom-section:not(.custom-section--row-desktop) > .custom-section__inner > .text-block-center-desktop {
      width: 100%;
    }

    .custom-section--grid .custom-section__inner {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }
  }
{% endstylesheet %}

