  "presets": [
    {
      "name": "t:collections_featured",
      "category": "t:collections",
      "settings": {
        "collection_list": [],
        "layout_type": "grid",
        "grid_columns": 4,
        "grid_columns_mobile": "2",
        "slider_items": 3,
        "slider_items_mobile": "1",
        "margin_top": 0,
        "margin_bottom": 0,
        "padding_top": 50,
        "padding_bottom": 50
