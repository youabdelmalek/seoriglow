{% assign collection_list = section.settings.collection_list | default: collections %}

<div
  class="
    collections-featured color-{{ section.settings.color_scheme }}
    {%- if section.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if section.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {{ section.settings.additional_class }}
  "
  style="--margin-top: {{ section.settings.margin_top }}px; --margin-bottom: {{ section.settings.margin_bottom }}px"
>
  <div
    class="collections-featured__inner page-width"
    style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px"
  >
    {% content_for 'blocks' %}

    {% if section.settings.layout_type == 'grid' %}
      <div
        class="collections-featured__grid"
        style="
          --grid-columns: {{ section.settings.grid_columns }};
          --grid-columns-mobile: {{ section.settings.grid_columns_mobile }};
        "
      >
        {% for collection in collection_list limit: section.settings.max_collections %}
          {% content_for 'block', type: '_collection-card', id: 'collection-card', closest.collection: collection %}
        {% endfor %}
      </div>
    {% elsif section.settings.layout_type == 'slider' %}
      {% capture slides %}
      {% for collection in collection_list limit: section.settings.max_collections %}
        <li class="splide__slide"> 
          <div class="slide" style="--margin-top: 0px; --margin-bottom: 0px;">
            {% # theme-check-disable %}
            {% content_for 'block', type: '_collection-card', id: 'collection-card', closest.collection: collection %}
            {% # theme-check-enable %}
          </div>
        </li>
      {% endfor %}
    {% endcapture %}

      {% render 'slider',
        block: section,
        slides: slides,
        gap: 16,
        show_arrows: section.settings.show_arrows,
        show_pagination: section.settings.show_pagination,
        per_page_desktop: section.settings.slider_items,
        per_page_mobile: section.settings.slider_items_mobile,
        rewind: section.settings.rewind
      %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .collections-featured {
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
  }

  .collections-featured__inner {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .collections-featured__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
    gap: var(--gap-md);
  }

  @media (width > 750px) {
    .collections-featured__grid {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:collections_featured",
  "disabled_on": {
    "groups": ["header", "footer", "custom.cart_drawer", "custom.breadcrumbs"]
  },
  "blocks": [
