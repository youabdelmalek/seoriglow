      "info": "t:collection_list_info"
    },
    {
      "type": "range",
      "id": "max_collections",
      "label": "t:max_collections",
      "min": 2,
      "max": 20,
      "default": 8,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:layout_type",
      "default": "grid",
      "options": [
        { "value": "grid", "label": "t:grid" },
        { "value": "slider", "label": "t:slider" }
      ]
    },
    {
      "type": "header",
      "content": "t:grid",
