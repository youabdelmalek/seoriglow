<script src="{{ 'cart-drawer.js' | asset_url }}" type="module"></script>

<cart-drawer
  class="cart-drawer{% if cart == empty %} cart-drawer--empty{% endif %}"
  data-ref="cart-drawer"
  data-section-id="{{ section.id }}"
  style="--cart-drawer-width: {{ section.settings.cart_drawer_width_on_desktop }}px;"
>
  <div
    class="
      cart-drawer__inner cart-drawer--{{ section.settings.cart_style }}
      {% if section.settings.cart_style == 'floating' or section.settings.cart_style == 'rounded' %} card{% endif %}
      color-{{ section.settings.color_scheme_body }}
      {% if section.settings.full_width_on_mobile %} cart-drawer--full-width-on-mobile{% endif %}
    "
    tabindex="-1"
  >
    {%- capture drawer_close -%}
      <button class="cart-drawer__close" type="button" onclick="this.closest('cart-drawer').close()">
        {% render 'icon', icon: 'close' %}
      </button>
    {%- endcapture -%}

    <div class="cart-drawer__header color-{{ section.settings.color_scheme_header }}">
      <div class="cart-drawer__header_title">
        <p class="h6">
          {{- 'cart.title' | t -}}
          {%- if section.settings.show_cart_count %} ({{ cart.item_count }}){%- endif -%}
        </p>

        {{ drawer_close }}
      </div>

      {% content_for 'block', type: '_cart-header-blocks', id: 'cart_header_blocks' %}
    </div>

    <div class="cart-drawer__body">
      <form action="{{ routes.cart_url }}" method="post" id="cart_drawer_form">
        <div class="cart-drawer__items">
          {%- assign previous_bundle_group = '' -%}
          {%- for item in cart.items -%}
            {%- assign bundle_name = '' -%}
            {%- assign current_bundle_group = '' -%}
            {%- assign has_visible_properties = false -%}
            {%- for property in item.properties -%}
              {%- assign property_first_char = property.first | slice: 0 -%}
              {%- if property.last != blank -%}
                {%- if property.first == 'Bundle' and property_first_char != '_' -%}
                  {%- assign bundle_name = property.last -%}
                {%- elsif property.first == '_bundle_group' -%}
                  {%- assign current_bundle_group = property.last -%}
                {%- elsif property_first_char != '_' and property.first != 'Bundle item' -%}
                  {%- assign has_visible_properties = true -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- assign selection_1_title = item.properties['_selection_1_title'] -%}
            {%- assign is_hidden_bundle = false -%}
            {%- if bundle_name != blank and current_bundle_group == blank and selection_1_title != blank -%}
              {%- assign is_hidden_bundle = true -%}
            {%- endif -%}
            {%- assign is_bundle_tail = false -%}
            {%- assign bundle_total_price = 0 -%}
            {%- assign bundle_compare_price = 0 -%}
            {%- assign next_bundle_group = '' -%}
            {%- unless forloop.last -%}
              {%- assign next_item = cart.items[forloop.index] -%}
              {%- assign next_bundle_group = next_item.properties._bundle_group -%}
            {%- endunless -%}
            {%- if current_bundle_group != blank -%}
              {%- if forloop.last -%}
                {%- assign is_bundle_tail = true -%}
              {%- elsif next_bundle_group != current_bundle_group -%}
                {%- assign is_bundle_tail = true -%}
              {%- endif -%}

              {%- if is_bundle_tail -%}
                {%- for bundled_item in cart.items -%}
                  {%- assign bundled_group = bundled_item.properties._bundle_group -%}
                  {%- if bundled_group == current_bundle_group -%}
                    {%- assign bundle_total_price = bundle_total_price | plus: bundled_item.final_line_price -%}
                    {%- assign bundled_compare_price = bundled_item.original_price -%}
                    {%- if bundled_item.variant.compare_at_price > bundled_item.original_price -%}
                      {%- assign bundled_compare_price = bundled_item.variant.compare_at_price -%}
                    {%- endif -%}
                    {%- assign bundled_compare_price = bundled_compare_price | times: bundled_item.quantity -%}
                    {%- assign bundle_compare_price = bundle_compare_price | plus: bundled_compare_price -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endif -%}

            {%- if bundle_name != blank and current_bundle_group != previous_bundle_group -%}
              {%- assign cart_drawer_bundle_open = '<div class="cart-drawer__bundle-group"><div class="cart-drawer__bundle-group-header"><span class="cart-drawer__bundle-group-label">' | append: bundle_name | append: '</span></div>' -%}
              {{- cart_drawer_bundle_open -}}
            {%- endif -%}

            <cart-drawer-item
              data-index="{{ item.index | plus: 1 }}"
              class="cart-drawer__item color-{{ section.settings.color_scheme_elements }}{% if section.settings.show_remove_button == false %} cart-drawer__item--no-remove-button{% endif %}{% if section.settings.color_scheme_elements != section.settings.color_scheme_body %} card{% endif %}{% if current_bundle_group != blank %} cart-drawer__item--bundle{% endif %}{% if current_bundle_group != blank and is_bundle_tail == false %} cart-drawer__item--bundle-child{% endif %}{% if is_hidden_bundle %} cart-drawer__item--bundle-product{% endif %}"
              data-ref="cart-item"
              data-product-handle="{{ item.product.handle }}"
              data-current-quantity="{{ item.quantity }}"
              {% if current_bundle_group != blank %}
                data-bundle-group="{{ current_bundle_group }}"
              {% endif %}
              {% if is_bundle_tail %}
                data-bundle-tail="true"
              {% endif %}
            >
              {% if is_hidden_bundle %}
              {% elsif item.image %}
                <a href="{{ item.url }}">
                  <img
                    src="{{ item.image | image_url: width: 150 }}"
                    alt="{{ item.product.title }}"
                    width="85"
                    height="{{ 85 | divided_by: item.image.aspect_ratio | ceil }}"
                  >
                </a>
              {% else %}
                <a href="{{ item.url }}">
                  <img
                    src="{{ 'placeholder-product.jpg' | asset_img_url: 'x150' }}"
                    alt="placeholder product"
                    width="85"
                    height="85"
                  >
                </a>
              {% endif %}

              <div class="cart-drawer__item-wrapper">
                <div class="cart-drawer__item-content">
                  {% if is_hidden_bundle %}
                    <div class="cart-drawer__bundle-product">
                      <div class="cart-drawer__bundle-product-header">
                        <span class="cart-drawer__bundle-product-label">{{ bundle_name }}</span>
                      </div>
                      <div class="cart-drawer__bundle-product-items">
                        {% for slot in (1..10) %}
                          {% assign selection_title_key = '_selection_' | append: slot | append: '_title' %}
                          {% assign selection_options_key = '_selection_' | append: slot | append: '_options' %}
                          {% assign selection_image_key = '_selection_' | append: slot | append: '_image' %}
                          {% assign selection_title = item.properties[selection_title_key] %}
                          {% assign selection_options = item.properties[selection_options_key] %}
                          {% assign selection_image = item.properties[selection_image_key] %}
                          {% if selection_title != blank %}
                            <div class="cart-drawer__bundle-product-item">
                              {% if selection_image != blank %}
                                <img src="{{ selection_image }}" alt="{{ selection_title | escape }}" width="56" height="56">
                              {% endif %}
                              <div class="cart-drawer__bundle-product-item-details">
                                <p class="cart-drawer__bundle-product-item-title">{{ selection_title }}</p>
                                {% if selection_options != blank %}
                                  <p class="cart-drawer__bundle-product-item-options">{{ selection_options }}</p>
                                {% endif %}
                              </div>
                            </div>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                  {% else %}
                    <a href="{{ item.url }}" class="cart-drawer__item-name">
                      {{- item.product.title | escape -}}
                    </a>

                    {%- if item.product.has_only_default_variant == false -%}
                      <div class="cart-drawer__item-options">
                        {%- for option in item.options_with_values -%}
                          {%- if section.settings.show_variant_options_labels == false -%}
                            <span>
                              {{- option.value -}}
                              {%- unless forloop.last %}, {% endunless -%}
                            </span>
                          {%- else -%}
                            <div class="cart-drawer__item-option">
                              <span>{{ option.name }}:</span>
                              <span>{{ option.value -}}</span>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if has_visible_properties -%}
                      <div class="cart-drawer__item-options">
                        {%- for property in item.properties -%}
                          {%- assign property_first_char = property.first | slice: 0 -%}
                          {%- if property.last != blank and property_first_char != '_' and property.first != 'Bundle' and property.first != 'Bundle item' -%}
                            <div class="cart-drawer__item-option">
                              <span>{{ property.first }}:</span>
                              <span>
                                {%- if property.last contains '/uploads/' -%}
                                  <a href="{{ property.last }}" target="_blank">
                                    {{- property.last | split: '/' | last -}}
                                  </a>
                                {%- else -%}
                                  {{ property.last }}
                                {%- endif -%}
                              </span>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if item.selling_plan_allocation.selling_plan != blank -%}
                      <div class="cart-drawer__item-options">
                        <p class="cart-drawer__item-option">
                          {{ item.selling_plan_allocation.selling_plan.name }}
                        </p>
                      </div>
                    {%- endif -%}
                  {% endif %}

                  {% if current_bundle_group == blank or is_bundle_tail %}
                    <div class="cart-drawer__item-prices{% if current_bundle_group != blank and is_bundle_tail %} cart-drawer__item-prices--bundle-tail{% endif %}">
                    <div class="cart-drawer__item-price">
                      {% assign compare_price = item.original_price %}
                      {% assign displayed_price = item.final_price %}
                      {% if item.variant.compare_at_price > item.original_price %}
                        {% assign compare_price = item.variant.compare_at_price %}
                      {% endif %}

                      {% if current_bundle_group != blank and is_bundle_tail %}
                        {% assign compare_price = bundle_compare_price %}
                        {% assign displayed_price = bundle_total_price %}
                      {% endif %}

                      {%- if compare_price > displayed_price -%}
                        {% render 'price', price: displayed_price, compare_price: compare_price, sales_badge: 'none' %}
                      {%- else -%}
                        {% render 'price', price: displayed_price, sales_badge: 'none' %}
                      {%- endif -%}

                      <div class="cart-drawer__item-discounts">
                        {%- for discount in item.line_level_discount_allocations -%}
                          <span class="cart-drawer__item-discount badge badge--secondary badge--small">
                            {% render 'icon', icon: 'shoppingmode' %}
                            <span>{{ discount.discount_application.title }}</span>
                          </span>
                        {%- endfor -%}
                      </div>
                    </div>
                    </div>
                  {% endif %}
                </div>

                {% if current_bundle_group == blank or is_bundle_tail %}
                  <div class="cart-drawer__item-actions{% if current_bundle_group != blank and is_bundle_tail %} cart-drawer__item-actions--bundle-tail{% endif %}">
                    <div class="cart-drawer__item-actions-wrapper{% if current_bundle_group != blank and is_bundle_tail %} cart-drawer__item-actions-wrapper--bundle-tail{% endif %}">
                      {%- if section.settings.show_remove_button -%}
                        <div class="{% if current_bundle_group != blank and is_bundle_tail %}cart-drawer__bundle-remove{% endif %}">
                        {% assign data_ref = 'data-ref="remove-item"' %}
                        {% assign data = data_ref %}

                        {% render 'button', button_shape: 'small', button_style: 'secondary', data: data, icon: 'delete' %}
                        </div>
                      {%- endif -%}

                      {% assign data_ref = 'data-ref="quantity-selector-input"' %}
                      {% assign data_buttons = 'data-ref="quantity-selector-button"' %}

                      {% assign max_quantity = item.variant.inventory_quantity %}
                      {% if item.variant.inventory_policy == 'continue' %}
                        {% assign max_quantity = 0 %}
                      {% endif %}

                      {% render 'quantity-selector',
                        small: true,
                        name: 'updates[]',
                        value: item.quantity,
                        min: -1,
                        max: max_quantity,
                        data_input: data_ref,
                        data_buttons: data_buttons
                      %}
                    </div>
                  </div>
                {% endif %}
              </div>
            </cart-drawer-item>
            {%- if current_bundle_group != blank and is_bundle_tail -%}
              {{- '</div>' -}}
            {%- endif -%}
            {%- assign previous_bundle_group = current_bundle_group -%}
          {%- endfor -%}
        </div>
      </form>
    </div>

    <div class="cart-drawer__footer color-{{ section.settings.color_scheme_footer }}">
      {% content_for 'block', type: '_cart-footer-resume-blocks', id: 'cart_footer_resume_blocks' %}

      <div class="cart-drawer__ctas">
        <button
          type="submit"
          data-ref="checkout-button"
          class="button button--full-width"
          name="checkout"
          form="cart_drawer_form"
          {% if cart == empty %}
            disabled
          {% endif %}
        >
          <span>{{ 'cart.checkout' | t }}</span>
          {% render 'loading-spinner' %}
        </button>
      </div>

      {% content_for 'block', type: '_cart-drawer-footer-blocks', id: 'cart_footer_blocks' %}
    </div>

    {%- if cart.empty? -%}
      <div class="cart-drawer__inner-empty">
        <p class="h4">{{ 'cart.empty_title' | t }}</p>
        {{ drawer_close }}
        {% content_for 'block', type: '_cart-drawer-empty-blocks', id: 'cart_drawer_empty_blocks' %}
      </div>
    {%- endif -%}
  </div>
</cart-drawer>

{% stylesheet %}
  :root {
    --cart-item-image-width: 80px;
  }

  cart-drawer {
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100%;
    display: flex;
    justify-content: flex-end;
    background: rgba(var(--color-shadow));
    opacity: 0;
    visibility: hidden;
    -webkit-backdrop-filter: brightness(1);
    backdrop-filter: brightness(1);
    transition: opacity var(--animation-speed) var(--animation-easing), visibility var(--animation-speed) var(--animation-easing);
  }

  cart-drawer.is-open {
    opacity: 1;
    visibility: visible;
    -webkit-backdrop-filter: brightness(0.75);
    backdrop-filter: brightness(0.75);
    transition: opacity var(--animation-speed) var(--animation-easing), visibility var(--animation-speed) var(--animation-easing),
      -webkit-backdrop-filter var(--animation-speed) var(--animation-easing), backdrop-filter var(--animation-speed) var(--animation-easing);
  }

  cart-drawer.is-open .cart-drawer__inner {
    animation: modalSlideInRight var(--animation-speed) var(--animation-easing) forwards;
  }

  cart-drawer.is-closing .cart-drawer__inner {
    animation: modalSlideOutRight var(--animation-speed) var(--animation-easing) forwards;
  }

  .cart-drawer__inner {
    height: 100%;
    width: var(--cart-drawer-width);
    max-width: calc(100vw - 30px);
    padding: 0 var(--padding-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    background-color: var(--color-background);
    color: var(--color-foreground);
    box-shadow: var(--modal-shadow);
  }

  @media (width <= 750px) {
    .cart-drawer__inner.cart-drawer--full-width-on-mobile {
      width: 100%;
      max-width: 100%;
    }
  }

  @media (width <= 350px) {
    .cart-drawer__inner {
      width: 100%;
    }
  }

  .cart-drawer .splide:not(.is-overflow) .splide__pagination {
    display: flex;
  }

  .cart-drawer .slider-block--with-pagination {
    padding-bottom: var(--margin-md);
  }

  .cart-drawer .splide__pagination {
    bottom: calc(-1 * var(--margin-md));
  }

  .cart-drawer--floating {
    margin: 15px;
    height: calc(100% - 30px);
  }

  .cart-drawer--rounded.card {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
  }

  .cart-drawer__inner-empty {
    height: 100%;
    padding: 0 var(--padding-sm);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: var(--gap-lg);
  }

  .cart-drawer__inner-empty > p {
    text-align: center;
  }

  .cart-drawer__inner-empty .cart-drawer__close {
    right: var(--padding-sm);
    position: absolute;
    top: var(--padding-sm);
  }

  .cart-drawer__bundle-group-header {
    margin: 0 0 0.15rem;
  }

  .cart-drawer__bundle-group-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .cart-drawer__bundle-remove {
    position: absolute;
    top: 0.45rem;
    right: 0.45rem;
    z-index: 2;
  }

  .cart-drawer__bundle-remove .button {
    min-width: 30px;
    min-height: 30px;
    padding: 0;
  }

  .cart-drawer__bundle-group {
    position: relative;
    padding: 0.55rem 0.65rem 0.45rem 1rem;
    border-radius: 12px;
    background: rgba(var(--color-foreground), 0.03);
  }

  .cart-drawer__bundle-group + .cart-drawer__bundle-group {
    margin-top: 0.4rem;
  }

  .cart-drawer__bundle-group::before {
    content: '';
    position: absolute;
    left: 0.45rem;
    top: 0.8rem;
    bottom: 0.7rem;
    width: 3px;
    border-radius: 999px;
    background: rgba(var(--color-foreground), 0.3);
  }

  .cart-drawer__bundle-group .cart-drawer__item {
    margin: 0;
  }

  .cart-drawer__bundle-group .cart-drawer__item + .cart-drawer__item {
    margin-top: 0.2rem;
  }

  .cart-drawer__bundle-group .cart-drawer__item.card {
    padding: 0.35rem 0;
    border: 0;
    box-shadow: none;
    background: transparent;
  }

  .cart-drawer__bundle-product {
    display: grid;
    gap: 0.8rem;
  }

  .cart-drawer__bundle-product-header {
    margin: 0;
  }

  .cart-drawer__bundle-product-label {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .cart-drawer__bundle-product-items {
    display: grid;
    gap: 0.7rem;
  }

  .cart-drawer__bundle-product-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .cart-drawer__bundle-product-item img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 10px;
    background: #fff;
    flex-shrink: 0;
  }

  .cart-drawer__bundle-product-item-details {
    min-width: 0;
  }

  .cart-drawer__bundle-product-item-title,
  .cart-drawer__bundle-product-item-options {
    margin: 0;
    line-height: 1.35;
  }

  .cart-drawer__bundle-product-item-title {
    font-size: var(--font-body--size);
    color: rgb(var(--color-foreground));
    font-weight: 500;
  }

  .cart-drawer__bundle-product-item-options {
    font-size: var(--font-body--size-small);
    color: rgba(var(--color-foreground), 0.8);
    margin-top: 0.2rem;
  }

  .cart-drawer__item--bundle-product .cart-drawer__item-prices {
    padding-left: calc(56px + 0.8rem);
  }

  .cart-drawer__bundle-group .cart-drawer__item-name {
    width: 100%;
  }

  .cart-drawer__item--bundle[data-bundle-tail='true'] .cart-drawer__item-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    min-height: auto;
  }

  .cart-drawer__item--bundle[data-bundle-tail='true'] .cart-drawer__item-actions {
    margin-left: auto;
  }

  @media screen and (max-width: 350px) {
    .cart-drawer__inner {
      max-width: calc(100vw - 10px);
    }

    .cart-drawer--floating {
      margin: 5px;
      height: calc(100% - 10px);
    }
  }

  /* Cart Drawer Empty State */

  .cart-drawer--empty .cart-drawer__header,
  .cart-drawer--empty .cart-drawer__body,
  .cart-drawer--empty .cart-drawer__footer {
    display: none;
  }

  cart-drawer:not(.cart-drawer--empty) .cart-drawer__inner-empty {
    display: none;
  }

  /* Cart Drawer Header */

  .cart-drawer__header {
    position: relative;
    padding: var(--padding-md);
    border-bottom: var(--separator-border-thickness) solid var(--color-border);
    margin-left: calc(-1 * var(--padding-md));
    width: calc(100% + (2 * var(--padding-md)));
  }

  .cart-drawer__header_title {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cart-drawer__header h2 {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 5px;
    color: rgb(var(--color-foreground));
  }

  .cart-drawer__close {
    display: inline-block;
    padding: 0;
    color: rgb(var(--color-foreground));
    background-color: transparent;
    border: none;
    cursor: pointer;
    height: 24px;
  }

  /* Cart Drawer Content */

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__items--disabled {
    pointer-events: none;
  }

  /* Cart Drawer Footer */

  .cart-drawer__footer {
    border-top: var(--separator-border-thickness) solid var(--color-border);
    padding: var(--padding-md);
    position: sticky;
    bottom: 0;
    background-color: var(--color-background);
    width: calc(100% + (2 * var(--padding-md)));
    margin-left: calc(-1 * var(--padding-md));
  }

  .cart-drawer__footer > *:not(:last-child) {
    margin-bottom: var(--padding-sm);
  }

  .cart-drawer__footer .accordion__header {
    padding: 0;
  }

  .cart-drawer__footer .accordion__content {
    padding: var(--padding-sm) 0;
  }

  /* Totals */

  .cart-drawer__totals,
  .cart-drawer__reductions {
    display: flex;
    justify-content: center;
    align-items: center;
    justify-content: space-between;
  }

  .cart-drawer__totals > * {
    color: rgb(var(--color-foreground));
    margin: 0;
    line-height: 1;
  }

  .cart-drawer__reductions p,
  .cart-drawer__totals p {
    font-weight: 500;
    margin: 0;
    line-height: normal;
  }

  .cart-drawer__reductions p,
  .cart-drawer__totals p,
  .cart-drawer__reductions-value,
  .cart-drawer__totals-value {
    font-size: var(--font-body--size-emphasized);
  }

  /* CTAs */

  .cart-drawer__ctas {
    text-align: center;
    display: flex;
    gap: 10px;
  }

  .cart-drawer__ctas button {
    width: 100%;
  }

  /* Items */

  .cart-drawer__body {
    overflow-y: auto;
    overflow-x: hidden;
    flex: 1;
    padding-right: calc(var(--padding-sm) / 2);
    margin-right: calc(-1 * (var(--padding-sm) / 2));
    padding-top: var(--padding-md);
  }

  .cart-item__error {
    display: flex;
    align-items: flex-start;
    width: min-content;
    min-width: 100%;
  }

  .cart-drawer__body::-webkit-scrollbar {
    width: 3px;
  }

  /* Item */

  .cart-drawer__item {
    background-color: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid #00000047;
    padding: 15px;
    border-radius: 10px;
    margin-bottom: var(--margin-lg);
    display: flex;
    gap: var(--gap-sm);
    align-items: flex-start;
    max-width: 100%;
  }

  .cart-drawer__item--loading {
    opacity: 0.5;
    pointer-events: none;
  }

  .cart-drawer__item:last-child {
    margin-bottom: var(--padding-sm);
  }

  .cart-drawer__item > a {
    display: flex;
    align-items: center;
  }

  .cart-drawer__item img {
    width: var(--cart-item-image-width);
    object-fit: cover;
    background-color: white;
    max-width: fit-content;
    border-radius: calc(var(--card-border-radius) - var(--padding-sm));
  }

  .cart-drawer__item.card {
    padding: var(--padding-sm);

    img {
      border-radius: calc(var(--card-border-radius) - var(--padding-sm));
    }
  }

  .cart-drawer__item-options,
  .cart-drawer__item-options p {
    line-height: normal;
    font-size: var(--font-body--size-small);
    word-break: break-word;
    color: rgba(var(--color-foreground), 0.8);
  }

  .cart-drawer__item-options .cart-drawer__item-option:not(:last-child) {
    margin-bottom: var(--padding-xs);
  }

  .cart-drawer__item-option {
    margin: 0;
  }

  .cart-drawer__item-content {
    display: flex;
    flex-direction: column;
    gap: 7px;
    margin-top: 5px;
    min-width: 0;
    flex: 1;
  }

  .cart-drawer__item-wrapper {
    display: flex;
    justify-content: space-between;
    width: 100%;
    min-height: var(--cart-item-image-width);
    gap: var(--gap-sm);
  }

  .cart-drawer__item-name {
    text-decoration: none;
    display: block;
    width: calc(100% + 60px);
    font-size: var(--font-body--size);
    color: rgb(var(--color-foreground));
    font-weight: 500;
    line-height: normal;
    margin-bottom: 0;
    transition: var(--animation-link-hover);

    &:hover {
      opacity: var(--opacity-link-hover);
    }
  }

  .cart-drawer__item-prices {
    position: relative;
    width: 100%;
  }

  .cart-drawer__item-prices.loading {
    width: max-content;
  }

  .cart-drawer__item-prices--bundle-tail {
    margin-top: 0.35rem;
  }

  .cart-drawer__item-price {
    display: flex;
    align-items: center;
    gap: var(--gap-xs);
    flex-wrap: wrap;
    font-size: var(--font-body--size-small);
    color: rgb(var(--color-foreground));
  }

  .cart-drawer__item-price > * {
    display: block;
    margin: 0;
    padding: 0;
    line-height: normal;
  }

  .cart-drawer__item-discounted-prices {
    display: flex;
    align-self: center;
    gap: 6px;
    line-height: normal;
  }

  .cart-drawer__item-compare-price {
    opacity: 0.7;
  }

  .cart-drawer__item--no-remove-button .cart-drawer__item-actions-wrapper {
    justify-content: flex-end;
  }

  .cart-drawer__item--no-remove-button .cart-drawer__item-name {
    width: calc(100% + var(--cart-item-image-width));
  }

  @media screen and (max-width: 350px) {
    .cart-drawer__item--no-remove-button .cart-drawer__item-name {
      width: calc(100% + 75px);
    }
  }

  @media screen and (max-width: 350px) {
    .cart-drawer__item img {
      width: var(--cart-item-image-width);
      max-height: calc(var(--cart-item-image-width) * 1.2);
    }

    .cart-drawer__item-content {
      gap: 5px;
    }

    .cart-drawer__item-wrapper {
      min-height: calc(var(--cart-item-image-width) * 1.2);
    }
    .cart-drawer__item-name {
      width: calc(100% + 50px);
    }

    .cart-drawer__item-prices {
      width: 100%;
    }
  }

  /* Quantity & Remove Button */

  .cart-drawer__item-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-drawer__item-actions--bundle-tail {
    margin-top: 0;
  }

  .cart-drawer__item-actions-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-direction: column;
    height: 100%;
    gap: 5px;
  }

  .cart-drawer__item-actions-wrapper--bundle-tail {
    margin-top: 0;
    height: auto;
    align-items: flex-end;
    justify-content: flex-end;
    flex-direction: column;
  }

  @media screen and (max-width: 749px) {
    .cart-drawer__item-actions-wrapper {
      flex-wrap: wrap;
    }
  }

  /* Discounts */

  .cart-drawer__discounts {
    margin-bottom: 0;
  }

  .cart-drawer__discount {
    margin-bottom: var(--padding-sm);
  }

  .cart-drawer__item-discounts,
  .cart-drawer__discounts {
    font-size: 12px;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .cart-drawer__item-discount,
  .cart-drawer__discount {
    min-width: max-content;
    gap: var(--gap-xs);
  }

  .cart-drawer__item-discount .icon {
    font-size: 14px !important;
  }

  .icon-discount {
    color: rgb(var(--color-foreground));
    width: 12px;
    height: 12px;
    margin-right: 7px;
  }

  .cart-drawer__item-discount span {
    max-width: 70px;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
  }

  @media screen and (max-width: 750px) {
    .cart-drawer__discounts {
      overflow: scroll;
      flex-wrap: nowrap;
    }

    .cart-drawer__discounts::-webkit-scrollbar {
      height: 3px;
    }
  }
{% endstylesheet %}

